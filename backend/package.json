{
  "name": "ximos-backend",
  "version": "1.0.0",
  "description": "Backend для системы финансового управления XimFinance",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "seed": "ts-node src/seeds/initial-data.ts",
    "seed:cost": "ts-node src/seeds/cost-calculation-data.ts",
    "seed:admin": "ts-node src/seeds/seed-admin.ts",
    "seed:content-bank": "ts-node src/seeds/seed-content-bank.ts",
    "seed:channels": "ts-node src/seeds/seed-channels.ts",
    "typeorm": "typeorm-ts-node-commonjs",
    "migration:generate": "npm run typeorm -- migration:generate",
    "migration:run": "npm run typeorm -- migration:run",
    "migration:revert": "npm run typeorm -- migration:revert"
  },
  "keywords": [
    "finance",
    "management",
    "chemistry"
  ],
  "author": "XimFinance Team",
  "license": "UNLICENSED",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.1",
    "@supabase/supabase-js": "^2.99.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/multer": "^2.0.0",
    "bcrypt": "^5.1.1",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "node-cron": "^4.2.1",
    "node-telegram-bot-api": "^0.67.0",
    "pg": "^8.11.3",
    "reflect-metadata": "^0.1.13",
    "typeorm": "^0.3.17",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.10.5",
    "@types/node-cron": "^3.0.11",
    "@types/node-telegram-bot-api": "^0.64.14",
    "nodemon": "^3.0.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3"
  }
}
