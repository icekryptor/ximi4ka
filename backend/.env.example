# Порт сервера
PORT=3001

# База данных (выберите один способ)
# Вариант 1 — Supabase / облачный PostgreSQL (одна строка):
# DATABASE_URL=postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres
#
# Вариант 2 — локальный PostgreSQL (отдельные переменные):
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=ximfinance
DATABASE_USER=ximfinance_user
DATABASE_PASSWORD=ximfinance_pass

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# Wildberries API (токен продвижения из ЛК WB, 180 дней)
WB_API_TOKEN=

# Окружение
NODE_ENV=development
