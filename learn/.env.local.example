NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Payments ---
# Provider selector: mock | tbank | yookassa | tpay | robokassa
# Default = mock (no external creds needed; pays via /checkout/mock-pay)
PAYMENT_PROVIDER=mock

# T-Bank acquiring (Тинькофф Касса). Get TerminalKey + Password from ЛК.
# Webhook URL to set in T-Bank cabinet:
#   <NEXT_PUBLIC_APP_URL>/api/orders/webhook/tbank
# TBANK_TERMINAL_KEY=
# TBANK_PASSWORD=
# TBANK_API_URL=https://securepay.tinkoff.ru/v2        # prod (default)
# TBANK_API_URL=https://rest-api-test.tinkoff.ru/v2    # test sandbox
# TBANK_TAXATION=usn_income   # ИП на УСН доходы
# TBANK_VAT=none              # ИП без НДС

# --- Device limit ---
# Default = OFF during testing. Set to "1" to enforce the per-user cap.
# DEVICE_LIMIT_ENFORCED=1
# DEVICE_LIMIT=5    # only consulted when enforcement is on

# --- Telegram notifications ---
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ADMIN_CHAT_ID=

# --- Legacy (kept for reference; Yandex Pay rejected our application) ---
# YANDEX_PAY_MERCHANT_ID=
# YANDEX_PAY_API_KEY=
